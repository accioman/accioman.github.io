{
  "name": "accioman-portfolio-codespace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/powershell:1": {}
  },
  "postCreateCommand": "python3 -m pip install --user --upgrade pip && npm --version && python3 --version && pwsh --version",
  "forwardPorts": [
    8000,
    5500
  ],
  "portsAttributes": {
    "8000": {
      "label": "Local web preview (python)",
      "onAutoForward": "notify"
    },
    "5500": {
      "label": "Alternative web preview",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "files.eol": "\n",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-vscode.powershell",
        "eamodio.gitlens",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "remoteUser": "vscode"
}
